# ─── Domain ────────────────────────────────────────────────────
DOMAIN=chat.moveisvalcenter.com.br
SSL_EMAIL=admin@moveisvalcenter.com.br

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=chatcenter
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# ─── Chatwoot ──────────────────────────────────────────────────
SECRET_KEY_BASE=CHANGE_ME_SECRET_KEY_BASE
FRONTEND_URL=https://chat.moveisvalcenter.com.br
DATABASE_URL=postgresql://chatcenter:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/chatwoot_production
REDIS_URL=redis://redis:6379/0
RAILS_MAX_THREADS=5
MAILER_SENDER_EMAIL=Chatcenter <noreply@moveisvalcenter.com.br>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=login
SMTP_ENABLE_STARTTLS_AUTO=true
ACTIVE_STORAGE_SERVICE=local

# ─── Evolution API ─────────────────────────────────────────────
EVOLUTION_API_KEY=CHANGE_ME_EVOLUTION_API_KEY

# ─── Supabase (cloud) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xzalvucjnrralddylfrl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_SUPABASE_SERVICE_ROLE_KEY

# ─── Asaas (billing) ──────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox

# ─── AI (Claude) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
